@page "/shell"
@attribute [Authorize(Policy = "InternalShell")]
@rendermode InteractiveServer
@layout ShellLayout
@using Microsoft.Extensions.Diagnostics.HealthChecks
@inject HealthCheckService HealthChecks

<PageTitle>Home — StillOps</PageTitle>

<section class="shell-page" aria-labelledby="page-heading">
    <h1 id="page-heading" class="page-heading">Workspace Home</h1>

    <AuthorizeView Policy="InternalShell">
        <Authorized>
            <p class="signed-in-summary">Signed in as: <strong>@context.User.Identity?.Name</strong></p>
        </Authorized>
    </AuthorizeView>

    <div class="status-card" role="region" aria-label="Platform status">
        <span class="status-chip status-chip--@OverallStatus.ToLowerInvariant()"
              aria-label="Platform status: @OverallStatus">@OverallStatus</span>
        <p>@SummaryMessage</p>
        <p><strong>Trust state:</strong> @TrustState</p>
    </div>

    <nav class="next-actions" aria-label="Next actions">
        <h2 class="section-heading">Next Actions</h2>
        <ul role="list">
            <li><a href="/shell/health" class="action-link">Open Health</a></li>
            <li><a href="/shell/configuration" class="action-link">Open Configuration</a></li>
        </ul>
    </nav>

    <aside class="scope-note" aria-label="Current scope">
        <h2 class="section-heading">Current Epic 1 Scope</h2>
        <p>Internal shell, platform health, and starter runtime configuration.</p>
    </aside>
</section>

@code {
    private string OverallStatus { get; set; } = "Unknown";
    private string SummaryMessage { get; set; } =
        PlatformHealthPresentation.GetSummaryMessage("Unknown", hasLastKnownState: false);
    private string TrustState { get; set; } =
        PlatformHealthPresentation.GetTrustState("Unknown", hasLastKnownState: false);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            HealthReport report = await HealthChecks.CheckHealthAsync();
            IReadOnlyList<PlatformHealthItemViewModel> items =
                PlatformHealthPresentation.BuildFreshItems(report, DateTimeOffset.Now);

            OverallStatus = PlatformHealthPresentation.GetOverallStatus(items);
            SummaryMessage = PlatformHealthPresentation.GetSummaryMessage(OverallStatus, hasLastKnownState: true);
            TrustState = PlatformHealthPresentation.GetTrustState(OverallStatus, hasLastKnownState: true);
        }
        catch
        {
            OverallStatus = "Unknown";
            SummaryMessage = PlatformHealthPresentation.GetSummaryMessage(OverallStatus, hasLastKnownState: false);
            TrustState = PlatformHealthPresentation.GetTrustState(OverallStatus, hasLastKnownState: false);
        }
    }
}
