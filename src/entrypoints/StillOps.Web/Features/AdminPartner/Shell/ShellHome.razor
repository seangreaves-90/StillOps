@page "/shell"
@attribute [Authorize(Policy = "InternalShell")]
@rendermode InteractiveServer
@layout ShellLayout

<PageTitle>Home — StillOps</PageTitle>

<section class="shell-page" aria-labelledby="page-heading">
    <h1 id="page-heading" class="page-heading">Workspace Home</h1>

    <AuthorizeView Policy="InternalShell">
        <Authorized>
            <p class="signed-in-summary">Signed in as: <strong>@context.User.Identity?.Name</strong></p>
        </Authorized>
    </AuthorizeView>

    <div class="status-card" role="region" aria-label="Platform status">
        <span class="status-chip status-chip--healthy" aria-label="Platform status: Healthy">Healthy</span>
        <p>All starter services are available.</p>
    </div>

    <nav class="next-actions" aria-label="Next actions">
        <h2 class="section-heading">Next Actions</h2>
        <ul role="list">
            <li><a href="/shell/health" class="action-link">Open Health</a></li>
            <li><a href="/shell/configuration" class="action-link">Open Configuration</a></li>
        </ul>
    </nav>

    <aside class="scope-note" aria-label="Current scope">
        <h2 class="section-heading">Current Epic 1 Scope</h2>
        <p>Internal shell, platform health, and starter runtime configuration.</p>
    </aside>
</section>
