@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager

<a class="skip-to-main" href="#main-content">Skip to main content</a>

<div class="shell-wrapper">
    <nav class="shell-rail" aria-label="Primary navigation">
        <div class="shell-brand" aria-label="StillOps">
            <span class="brand-name">StillOps</span>
        </div>
        <ul class="shell-nav-list" role="list">
            <li>
                <NavLink class="shell-nav-link" href="/shell" Match="NavLinkMatch.All">
                    Home
                </NavLink>
            </li>
            <li>
                <NavLink class="shell-nav-link" href="/shell/health" Match="NavLinkMatch.Prefix">
                    Health
                </NavLink>
            </li>
            <li>
                <NavLink class="shell-nav-link" href="/shell/configuration" Match="NavLinkMatch.Prefix">
                    Configuration
                </NavLink>
            </li>
        </ul>
    </nav>

    <div class="shell-content">
        <header class="shell-header">
            <div class="shell-header-title" aria-live="polite">
                <p class="shell-section-label">Current section</p>
                <h1 class="shell-header-heading">@CurrentPageTitle</h1>
            </div>

            <div class="shell-identity" aria-label="Signed-in user controls">
                <AuthorizeView>
                    <Authorized>
                        <span class="signed-in-name" aria-label="Signed in as @context.User.Identity?.Name">
                            @context.User.Identity?.Name
                        </span>
                        <form method="post" action="/logout" class="signout-form">
                            <AntiforgeryToken />
                            <button type="submit" class="btn-signout">Sign Out</button>
                        </form>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="shell-main" id="main-content" tabindex="-1">
            @Body
        </main>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private string CurrentPageTitle => GetPageTitle();

    private string GetPageTitle()
    {
        string relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        string normalizedPath = "/" + relativePath.Split('?', '#')[0].Trim('/');

        return normalizedPath switch
        {
            "/shell" => "Workspace Home",
            "/shell/health" => "Platform Health",
            "/shell/configuration" => "Configuration",
            _ => "StillOps Shell"
        };
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
